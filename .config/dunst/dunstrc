[global]
frame_color = "#4c566ab0"
separator_color= frame
scale = 1.2
icon_corner_radius = 5
font = "JetBrains Mono Nerd Font 12"
origin = top-center
offset = 0
frame_width = 4
corners = all
corner_radius = 10

[urgency_low]
background = "#2e3440b0"
foreground = "#d8dee9"

[urgency_normal]
background = "#2e3440b0"
foreground = "#d8dee9"

[urgency_critical]
background = "#2e3440b0"
foreground = "#d8dee9"
frame_color = "#d08770b0"
